{
  "expo": {
    "name": "Ndjan-Soko",
    "slug": "ndjan-soko",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1D6B4E"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1D6B4E"
      },
      "package": "com.keyce.ndjansoko"
    },
    "ios": {
      "bundleIdentifier": "com.keyce.ndjansoko"
    },
    "plugins": [
      "expo-location",
      [
        "expo-camera",
        { "cameraPermission": "Ndjan-Soko utilise la caméra pour analyser vos récoltes." }
      ]
    ],
    "scheme": "ndjansoko"
  }
}
